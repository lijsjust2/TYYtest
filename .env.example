# 天翼云盘签到脚本 - 环境变量配置示例
# 复制此文件为 .env 并填入你的实际配置

# ============================================
# 必需配置
# ============================================

# 账号密码配置
# 格式：账号1 密码1 账号2 密码2 （空格分隔）
# 示例：13800138000 password123 13900139000 password456
TYYS="账号1 密码1 账号2 密码2"

# ============================================
# 推送配置（至少配置一种）
# ============================================

# 钉钉推送（原有方式，保持兼容）
DINGTALK_TOKEN="your_dingtalk_token"
# 可选：钉钉机器人安全设置的 secret（仅当开启签名校验时需要）
DINGTALK_SECRET="your_dingtalk_secret"

# Server酱推送（可选）
# 获取方式：https://sct.ftqq.com/
SCT_SEND_KEY="your_serverchan_key"

# Telegram推送（可选）
# 获取方式：找 @BotFather 创建机器人，获取 token
TELEGRAM_BOT_TOKEN="your_telegram_bot_token"
# 获取方式：发送消息给 @userinfobot 获取 chat_id
TELEGRAM_CHAT_ID="your_telegram_chat_id"

# 企业微信推送（可选）
# 获取方式：https://developer.work.weixin.qq.com/document/path/91770
WECOM_BOT_KEY="your_wecom_webhook_key"
WECOM_BOT_TELPHONE="your_phone_number"

# WxPusher推送（可选）
# 获取方式：https://wxpusher.zjiecode.com/
WX_PUSHER_APP_TOKEN="your_wxpusher_app_token"
WX_PUSHER_UID="your_wxpusher_uid"

# PushPlus推送（可选）
# 获取方式：https://www.pushplus.plus/
PUSH_PLUS_TOKEN="your_pushplus_token"

# Bark推送（可选，iOS专用）
# 获取方式：https://bark.day.app/
BARK_KEY="your_bark_key"
# 自定义Bark服务器地址（可选，默认使用官方服务器）
BARK_SERVER="https://api.day.app"
# 自定义分组名（可选，默认为"天翼云盘"）
BARK_GROUP="天翼签到"

# ============================================
# 可选配置
# ============================================

# 调试模式（可选）
# 设置为 1 开启 SDK 详细日志，用于调试问题
CLOUD189_VERBOSE=0

# 钉钉消息类型（可选）
# markdown（默认）或 text
DINGTALK_MSGTYPE="markdown"

# ============================================
# 家庭云配置（可选）
# ============================================

# 家庭云ID（可选）
# 获取教程：https://alist.nn.ci/zh/guide/drivers/189.html
TYY_FAMILY_ID=""

# 个人签到是否只签主账号（可选）
# true: 只签主账号
# false: 签到所有账号（默认）
PRIVATE_ONLY_FIRST="false"

# ============================================
# 多线程和多次签到配置（可选）
# ============================================

# 并发数（单个账号同时签到的线程数）
# 默认：3
# 说明：单个账号同时并发签到多次，提高签到速度
CONCURRENT_LIMIT=3

# 每个账号签到次数
# 默认：3
# 说明：每个账号会连续签到多次，领取更多奖励
SIGN_TIMES=3
